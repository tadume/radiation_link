<p id="notice"><%= notice %></p>

<h1>最近の記事</h1>
<%= render partial: "search" %>

<table>
  <thead>
    <tr>
      <th>タイトル</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <%= paginate @articles %>
    <% @articles.each do |article| %>
      <tr>
        <td>
        <%= article.title %>
        <%article.tags.each do |tag|%>
          <span class="badge rounded-pill bg-primary"><%= tag.name%></span>
        <% end %>
        </td>

        <td><%= link_to "Show", article %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
