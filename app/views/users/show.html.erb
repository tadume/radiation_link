<p><%= "ユーザー名: #{@user.name}" %></p>
<p><%= "フォロー数: #{@user.follower.count}" %></p>
<p><%= "フォロワー数: #{@user.followed.count}" %></p>
<% unless @user == current_user %>
  <% if current_user.following?(@user) %>
    <%= link_to 'フォロー外す', unfollow_path(params[:id]), method: :POST %>
  <% else %>
    <%= link_to 'フォローする', follow_path(params[:id]), method: :POST %>
  <% end %>
<% end %>
